# ─── LLM Provider API Keys ────────────────────────────────────────────────────
# Add at least one. ASTRA works in simulated mode if none are set.

GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
XAI_API_KEY=your_xai_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ─── Google Vertex AI (optional, no API key required) ─────────────────────────
# Uses Application Default Credentials. Run once: gcloud auth application-default login
# Then set your GCP project ID below.

VERTEX_PROJECT=your_gcp_project_id
VERTEX_LOCATION=us-central1

# ─── Default Provider ─────────────────────────────────────────────────────────
# Production: codex_cli | claude_cli | agy_cli
# Optional APIs: gemini | anthropic | openai | vertexai | deepseek | xai | qwen
#               mistral | codestral | groq | perplexity
# If unset, ASTRA picks the first configured provider automatically.

ASTRA_PROVIDER=codex_cli

# ─── Per-Phase Providers (optional) ───────────────────────────────────────────
# Override which provider handles each phase. Falls back to ASTRA_PROVIDER.

ASTRA_CONJECTURE_PROVIDER=codex_cli,agy_cli
ASTRA_TRANSLATOR_PROVIDER=claude_cli
ASTRA_REVIEWER_PROVIDER=codex_cli
ASTRA_ANALYST_PROVIDER=codex_cli
ASTRA_NAVIGATOR_PROVIDER=agy_cli
ASTRA_SYNTH_PROVIDER=codex_cli

# Recommended production model selection (subscription CLIs, no model API keys).
ASTRA_CLAUDE_MODELS=claude-opus-4-8,sonnet
ASTRA_CODEX_MODELS=gpt-5.6-sol
ASTRA_CODEX_REASONING=xhigh
ASTRA_AGY_MODELS=gemini-3.1-pro-high,gemini-3.5-flash-high
ASTRA_TRANSLATOR_MODELS=claude-opus-4-8,sonnet
ASTRA_CODE_REVIEW=1
ASTRA_REVIEW_MAX_REVISIONS=1
ASTRA_NAVIGATE_AFTER_CYCLE=1

# ─── Remote Validation Oracle (optional) ─────────────────────────────────────
# Keep ASTRA UI local while running Phase 4 validation scripts on a Linux worker
# reachable over SSH/Tailscale.

# ASTRA_ORACLE_MODE=local
# ASTRA_ORACLE_MODE=remote
# ASTRA_ORACLE_TIMEOUT=600
# ASTRA_REMOTE_HOST=user@compute-host.example
# ASTRA_REMOTE_PYTHON=~/astra-worker/venv/bin/python
# ASTRA_REMOTE_WORKER=~/astra-worker/astra_remote_worker.py
# ASTRA_REMOTE_WORKDIR=~/astra-worker/workspace
# ASTRA_REMOTE_CONNECT_TIMEOUT=15
# ASTRA_REMOTE_SSH_OPTIONS=-i C:\path\to\ssh_key -o "ProxyCommand=tailscale nc %h %p"
