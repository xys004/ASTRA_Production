# ─── LLM Provider API Keys ────────────────────────────────────────────────────
# Add at least one. ASTRA works in simulated mode if none are set.

GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
XAI_API_KEY=your_xai_api_key_here
DASHSCOPE_API_KEY=your_dashscope_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ─── Google Vertex AI (optional, no API key required) ─────────────────────────
# Uses Application Default Credentials. Run once: gcloud auth application-default login
# Then set your GCP project ID below.

VERTEX_PROJECT=your_gcp_project_id
VERTEX_LOCATION=us-central1

# ─── Default Provider ─────────────────────────────────────────────────────────
# Options: gemini | anthropic | openai | vertexai
# If unset, ASTRA picks the first configured provider automatically.

ASTRA_PROVIDER=gemini

# ─── Per-Phase Providers (optional) ───────────────────────────────────────────
# Override which provider handles each phase. Falls back to ASTRA_PROVIDER.

# ASTRA_CONJECTURE_PROVIDER=gemini
# ASTRA_TRANSLATOR_PROVIDER=anthropic
# ASTRA_ANALYST_PROVIDER=openai

# ─── Remote Validation Oracle (optional) ─────────────────────────────────────
# Keep ASTRA UI local while running Phase 4 validation scripts on a Linux worker
# reachable over SSH/Tailscale.

# ASTRA_ORACLE_MODE=local
# ASTRA_ORACLE_MODE=remote
# ASTRA_ORACLE_TIMEOUT=600
# ASTRA_REMOTE_HOST=astrum@100.66.143.117
# ASTRA_REMOTE_PYTHON=~/astra-worker/venv/bin/python
# ASTRA_REMOTE_WORKER=~/astra-worker/astra_remote_worker.py
# ASTRA_REMOTE_WORKDIR=~/astra-worker/workspace
# ASTRA_REMOTE_CONNECT_TIMEOUT=15
# ASTRA_REMOTE_SSH_OPTIONS=-i C:\Users\Nelson\.ssh\google_compute_engine -o "ProxyCommand=tailscale nc %h %p"
